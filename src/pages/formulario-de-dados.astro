---
import DataForm from '@/components/data-form';
import Layout from '../layouts/Layout.astro';


---

<Layout class="bg-background">
	<form name="formulario-de-dados" data-netlify="true" hidden>
		<input name="who" />
		<input name="reason" />
		<input name="name" />
		<input name="email" />
		<input name="phone" />
		<input name="additionalInfo" />
	</form>
	<div class="w-full flex justify-center">
		<div class="w-fullpx-6 lg:px-12 py-10 flex flex-col">
			<DataForm client:load />
		</div>
	</div>
</Layout>
